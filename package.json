{
  "name": "frontend-editor",
  "description": "Editor visuale local-first per siti e applicazioni con Codex integrato.",
  "author": "Frontend Editor contributors",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "bin": {
    "frontend-editor": "bin/frontend-editor.mjs"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:package": "npm run build && electron-forge package",
    "desktop:make": "npm run build && electron-forge make",
    "desktop:test": "playwright test e2e/desktop-shell.spec.ts e2e/desktop-production.spec.ts --workers=1",
    "desktop:test:packaged": "node scripts/test-desktop-packaged.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "export:sample": "vite-node scripts/materialize-export.ts",
    "test:generated": "playwright test --config=playwright.generated.config.ts",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@xyflow/react": "^12.9.3",
    "electron-squirrel-startup": "^1.0.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^43.1.1",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
