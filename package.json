{
  "name": "kyro-studio",
  "description": "Kyro is a local-first visual low-code studio with an integrated Codex agent.",
  "author": "Kyro contributors",
  "private": true,
  "version": "2.1.0",
  "bin": {
    "kyro": "bin/frontend-editor.mjs"
  },
  "files": [
    ".agents/skills/kyro-actions",
    ".agents/skills/kyro-app",
    ".agents/skills/kyro-data",
    ".agents/skills/kyro-design",
    ".agents/skills/kyro-extensions",
    ".agents/skills/kyro-live-context",
    ".agents/skills/kyro-native",
    ".agents/skills/kyro-publish",
    ".agents/skills/kyro-test",
    "bin",
    "scripts/kyro-start.mjs",
    "server",
    "src",
    "index.html",
    "vite.config.ts",
    "tsconfig*.json",
    "CHANGELOG.md"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "node bin/frontend-editor.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "export:sample": "vite-node scripts/materialize-export.ts",
    "export:specialized": "vite-node scripts/materialize-specialized-exports.ts",
    "export:native-verification": "vite-node scripts/materialize-native-export.ts",
    "test:generated": "playwright test --config=playwright.generated.config.ts",
    "build:specialized": "node node_modules/vite/bin/vite.js build out/experience-landing && node node_modules/vite/bin/vite.js build out/experience-dashboard",
    "test:specialized": "npm run build:specialized && playwright test --config=playwright.specialized.config.ts",
    "release:evidence": "node scripts/release-evidence.mjs",
    "release:verify": "vitest run tests/release.test.ts",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@xyflow/react": "^12.9.3",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.4",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Musca420/kyro-visual-low-code-studio.git"
  },
  "keywords": [
    "visual-programming",
    "low-code",
    "codex",
    "pwa",
    "android"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Musca420/kyro-visual-low-code-studio/issues"
  },
  "homepage": "https://github.com/Musca420/kyro-visual-low-code-studio#readme",
  "main": "eslint.config.js"
}
